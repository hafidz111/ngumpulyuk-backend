# Environment Variables Template
# Salin file ini ke .env dan isi nilainya
# File .env TIDAK boleh di-commit ke Git

# ─── Django Core ────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-generate-new-one-for-production
DEBUG=True
DJANGO_ENV=development           # 'development' (SQLite) atau 'production' (Supabase)
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────
# Hanya diisi saat DJANGO_ENV=production
# Ambil dari: Supabase Dashboard → Settings → Database → Connection string → URI
# Gunakan Transaction Pooler (port 6543) bukan Direct Connection
# DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ─── Frontend ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Email (Mailtrap) ────────────────────────────────────────
EMAIL_HOST_USER=your-mailtrap-user
EMAIL_HOST_PASSWORD=your-mailtrap-password

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
SOCIAL_AUTH_PASSWORD=your-social-auth-password
